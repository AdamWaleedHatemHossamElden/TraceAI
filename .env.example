# Shared
NODE_ENV=development

# Backend
BACKEND_PORT=5000
BACKEND_API_PREFIX=/api
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=traceai
DATABASE_USER=traceai_user
DATABASE_PASSWORD=change_me_locally
JWT_SECRET=replace_with_local_secret
AI_SERVICE_URL=http://ai-service:8000
UPLOAD_STORAGE_PATH=./storage/uploads

# AI service
AI_SERVICE_PORT=8000
AI_SERVICE_NAME=traceai-ai-service

# MySQL container defaults for local Docker Compose
MYSQL_DATABASE=traceai
MYSQL_USER=traceai_user
MYSQL_PASSWORD=change_me_locally
MYSQL_ROOT_PASSWORD=change_me_root_locally
